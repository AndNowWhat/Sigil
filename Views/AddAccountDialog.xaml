<Window x:Class="Sigil.Views.AddAccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Account"
        Width="320"
        MinHeight="220"
        WindowStartupLocation="CenterOwner"
        SizeToContent="Height"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Choose account type"
                   FontSize="16"
                   FontWeight="SemiBold"
                   Margin="0,0,0,12"/>

        <StackPanel Grid.Row="1"
                    Margin="0,0,0,12">
            <Button Content="Jagex Account"
                    Height="36"
                    Margin="0,0,0,8"
                    Click="OnJagex"/>
            <Button Content="Steam Account"
                    Height="36"
                    Click="OnSteam"/>
        </StackPanel>

        <Button Grid.Row="2"
                Content="Cancel"
                Width="80"
                HorizontalAlignment="Right"
                Margin="0,12,0,0"
                Click="OnCancel"/>
    </Grid>
</Window>
